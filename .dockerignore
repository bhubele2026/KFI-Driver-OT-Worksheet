node_modules
**/node_modules
dist
**/dist
.git
.gitignore

# Replit + local dev cruft
.local
.replit
.replitignore
replit.nix
.agents
attached_assets/**/*.zip
exports

# Editor / OS
.idea
.vscode
.DS_Store
*.log
*.orig
