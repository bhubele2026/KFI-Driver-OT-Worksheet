{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./seedDriverPayrollProfiles": "./src/seedDriverPayrollProfiles.ts"
  },
  "scripts": {
    "pre-migrate": "tsx ./src/preMigrate.ts",
    "push": "pnpm run pre-migrate && drizzle-kit push --force --config ./drizzle.config.ts",
    "push-interactive": "pnpm run pre-migrate && drizzle-kit push --config ./drizzle.config.ts",
    "check-drift": "tsx ./src/checkDrift.ts",
    "test": "node --import tsx --test 'src/__tests__/*.test.ts'"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "catalog:"
  }
}
